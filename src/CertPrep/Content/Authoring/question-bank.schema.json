{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://certprep.local/contracts/question-bank-v1.schema.json",
  "title": "CertPrep portable question bank",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "exams"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "exams": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/exam" }
    }
  },
  "$defs": {
    "contentKey": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]{1,100}$"
    },
    "exam": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "code",
        "title",
        "summary",
        "contentVersion",
        "objectives",
        "questions"
      ],
      "properties": {
        "provider": { "type": "string", "minLength": 1 },
        "code": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "contentVersion": { "type": "string", "minLength": 1 },
        "objectives": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/objective" }
        },
        "questions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/question" }
        }
      }
    },
    "objective": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contentKey", "name", "sortOrder"],
      "properties": {
        "contentKey": { "$ref": "#/$defs/contentKey" },
        "name": { "type": "string", "minLength": 1 },
        "sortOrder": { "type": "integer" }
      }
    },
    "choice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "isCorrect", "sortOrder"],
      "properties": {
        "text": { "type": "string", "minLength": 1 },
        "isCorrect": { "type": "boolean" },
        "sortOrder": { "type": "integer" }
      }
    },
    "question": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contentKey",
        "objectiveKey",
        "prompt",
        "kind",
        "difficulty",
        "explanation",
        "sourceName",
        "sourceUrl",
        "isActive",
        "choices"
      ],
      "properties": {
        "contentKey": { "$ref": "#/$defs/contentKey" },
        "objectiveKey": { "$ref": "#/$defs/contentKey" },
        "prompt": { "type": "string", "minLength": 1 },
        "kind": {
          "enum": ["SingleChoice", "MultipleChoice", "TrueFalse"]
        },
        "difficulty": {
          "enum": ["Foundation", "Intermediate", "Advanced"]
        },
        "explanation": { "type": "string", "minLength": 1 },
        "sourceName": { "type": "string", "minLength": 1 },
        "sourceUrl": { "type": "string", "format": "uri" },
        "isActive": { "type": "boolean" },
        "choices": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/choice" },
          "contains": {
            "properties": { "isCorrect": { "const": false } },
            "required": ["isCorrect"]
          },
          "minContains": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "kind": { "const": "SingleChoice" } },
            "required": ["kind"]
          },
          "then": {
            "properties": {
              "choices": {
                "contains": {
                  "properties": { "isCorrect": { "const": true } },
                  "required": ["isCorrect"]
                },
                "minContains": 1,
                "maxContains": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": { "kind": { "const": "MultipleChoice" } },
            "required": ["kind"]
          },
          "then": {
            "properties": {
              "choices": {
                "contains": {
                  "properties": { "isCorrect": { "const": true } },
                  "required": ["isCorrect"]
                },
                "minContains": 2
              }
            }
          }
        },
        {
          "if": {
            "properties": { "kind": { "const": "TrueFalse" } },
            "required": ["kind"]
          },
          "then": {
            "properties": {
              "choices": {
                "minItems": 2,
                "maxItems": 2,
                "prefixItems": [
                  {
                    "allOf": [
                      { "$ref": "#/$defs/choice" },
                      { "properties": { "text": { "const": "True" } } }
                    ]
                  },
                  {
                    "allOf": [
                      { "$ref": "#/$defs/choice" },
                      { "properties": { "text": { "const": "False" } } }
                    ]
                  }
                ],
                "contains": {
                  "properties": { "isCorrect": { "const": true } },
                  "required": ["isCorrect"]
                },
                "minContains": 1,
                "maxContains": 1
              }
            }
          }
        }
      ]
    }
  }
}
