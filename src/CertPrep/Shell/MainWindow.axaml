<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:CertPrep.Shell"
        x:Class="CertPrep.Shell.MainWindow"
        x:DataType="shell:ShellViewModel"
        Title="CertPrep"
        Width="1360"
        Height="840"
        MinWidth="920"
        MinHeight="640"
        Icon="/Assets/App/certprep-icon.png"
        Closing="WindowClosing"
        WindowStartupLocation="CenterScreen">

  <Grid ColumnDefinitions="210,*">
    <Border Background="{DynamicResource SidebarBrush}"
            BorderBrush="{DynamicResource StrokeBrush}"
            BorderThickness="0,0,1,0"
            Padding="16">
      <Grid RowDefinitions="Auto,*">
        <StackPanel Orientation="Horizontal" Spacing="9">
            <Image Width="30" Height="30" Source="/Assets/App/certprep-icon.png" />
            <TextBlock Text="CertPrep" FontSize="19" FontWeight="Bold" VerticalAlignment="Center" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,28,0,0" Spacing="5">
          <Button Classes="nav"
                  Command="{Binding ShowDashboardCommand}"
                  IsEnabled="{Binding IsNavigationEnabled}">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <PathIcon Width="15" Height="15" Data="{StaticResource Icon.Dashboard}" />
              <TextBlock Text="Dashboard" />
            </StackPanel>
          </Button>
          <Button Classes="nav"
                  Command="{Binding ShowProgressCommand}"
                  IsEnabled="{Binding IsNavigationEnabled}">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <PathIcon Width="15" Height="15" Data="{StaticResource Icon.Progress}" />
              <TextBlock Text="Progress" />
            </StackPanel>
          </Button>
          <Button Classes="nav"
                  Tag="OptionsPage"
                  Command="{Binding ShowOptionsCommand}"
                  IsEnabled="{Binding IsNavigationEnabled}">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <PathIcon Width="15" Height="15" Data="{StaticResource Icon.Options}" />
              <TextBlock Text="Options" />
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Column="1" RowDefinitions="Auto,*">
      <Border BorderBrush="{DynamicResource StrokeBrush}"
              BorderThickness="0,0,0,1"
              Padding="26,14"
              IsVisible="{Binding ShowPageHeader}">
        <Grid>
          <TextBlock Text="{Binding PageTitle}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
        </Grid>
      </Border>

      <ContentControl Grid.Row="1" Content="{Binding CurrentPage}" />
    </Grid>
  </Grid>
</Window>
