<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CertPrep.Features.Practice"
             x:Class="CertPrep.Features.Practice.Views.PracticeView"
             x:DataType="vm:PracticeViewModel">
  <Grid RowDefinitions="Auto,*">
    <Border Grid.Row="0"
            Background="{DynamicResource CanvasBrush}"
            BorderBrush="{DynamicResource StrokeBrush}"
            BorderThickness="0,0,0,1"
            Padding="16,12,16,10">
      <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
        <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="12">
          <TextBlock Text="{Binding ExamCode}"
                     FontSize="18"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center" />
          <Border Grid.Column="1"
                  Width="1"
                  Height="18"
                  Background="{DynamicResource StrokeBrush}"
                  VerticalAlignment="Center" />
          <TextBlock Grid.Column="2"
                     Text="{Binding QuestionPosition}"
                     Classes="muted"
                     FontSize="12"
                     VerticalAlignment="Center" />
          <Button Grid.Column="3"
                  Classes="secondary"
                  Content="Save for later"
                  Command="{Binding ExitCommand}" />
        </Grid>

        <ProgressBar Grid.Row="1"
                     Minimum="0"
                     Maximum="100"
                     Value="{Binding ProgressValue}" />
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
      <Border Classes="card" Margin="16" Padding="20">
        <StackPanel Spacing="14">
          <StackPanel Spacing="7">
            <TextBlock Text="{Binding ObjectiveName}" Classes="eyebrow" />
            <TextBlock Text="{Binding QuestionText}" FontSize="20" FontWeight="SemiBold" TextWrapping="Wrap" LineHeight="27" />
            <TextBlock Text="{Binding AnswerInstruction}" Classes="muted" FontSize="13" />
          </StackPanel>

          <ItemsControl x:Name="ChoiceList"
                        ItemsSource="{Binding Choices}"
                        HorizontalAlignment="Stretch">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:ChoiceOptionViewModel">
                <ToggleButton Classes="choice"
                              Classes.correct="{Binding ShowCorrectIndicator}"
                              Classes.incorrect="{Binding ShowIncorrectIndicator}"
                              Tag="AnswerChoice"
                              Width="{Binding #ChoiceList.Bounds.Width}"
                              HorizontalAlignment="Stretch"
                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                              IsEnabled="{Binding CanChangeSelection}">
                  <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                    <Grid Width="18" Height="18" VerticalAlignment="Center">
                      <Border Classes="choiceBox" IsVisible="{Binding UsesCheckboxIndicator}">
                        <TextBlock Text="✓"
                                   IsVisible="{Binding IsSelected}"
                                   Foreground="White"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                      </Border>
                      <Border Classes="choiceRadio" IsVisible="{Binding UsesRadioIndicator}">
                        <Ellipse Classes="choiceMark"
                                 Width="8"
                                 Height="8"
                                 Fill="{DynamicResource AccentStrongBrush}"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 IsVisible="{Binding IsSelected}" />
                      </Border>
                    </Grid>
                    <TextBlock Grid.Column="1" Text="{Binding Text}" TextWrapping="Wrap" VerticalAlignment="Center" FontWeight="Normal" />
                    <Grid Grid.Column="2" Width="30">
                      <TextBlock Text="✓" Foreground="{DynamicResource SuccessBrush}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" IsVisible="{Binding ShowCorrectIndicator}" />
                      <TextBlock Text="×" Foreground="{DynamicResource DangerBrush}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" IsVisible="{Binding ShowIncorrectIndicator}" />
                    </Grid>
                  </Grid>
                </ToggleButton>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <Grid IsVisible="{Binding ShowFeedback}">
            <Border Background="{DynamicResource SuccessSoftBrush}"
                    BorderBrush="{DynamicResource SuccessBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    IsVisible="{Binding FeedbackIsCorrect}" />
            <Border Background="{DynamicResource DangerSoftBrush}"
                    BorderBrush="{DynamicResource DangerBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    IsVisible="{Binding !FeedbackIsCorrect}" />

            <StackPanel Margin="18" Spacing="9">
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <Border Width="30"
                        Height="30"
                        CornerRadius="15"
                        Background="{DynamicResource SuccessBrush}"
                        IsVisible="{Binding FeedbackIsCorrect}">
                  <TextBlock Text="✓" Foreground="White" FontSize="17" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <Border Width="30"
                        Height="30"
                        CornerRadius="15"
                        Background="{DynamicResource DangerBrush}"
                        IsVisible="{Binding !FeedbackIsCorrect}">
                  <TextBlock Text="×" Foreground="White" FontSize="21" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Grid.Column="1"
                           Text="{Binding FeedbackHeading}"
                           FontSize="17"
                           FontWeight="Bold"
                           Foreground="{DynamicResource SuccessBrush}"
                           VerticalAlignment="Center"
                           IsVisible="{Binding FeedbackIsCorrect}" />
                <TextBlock Grid.Column="1"
                           Text="{Binding FeedbackHeading}"
                           FontSize="17"
                           FontWeight="Bold"
                           Foreground="{DynamicResource DangerBrush}"
                           VerticalAlignment="Center"
                           IsVisible="{Binding !FeedbackIsCorrect}" />
              </Grid>
              <TextBlock Text="{Binding Explanation}" TextWrapping="Wrap" LineHeight="21" />
              <Border Height="1" Background="{DynamicResource StrokeBrush}" Margin="0,4" />
              <TextBlock Text="SOURCE" Classes="eyebrow" />
              <TextBlock Text="{Binding SourceName}" FontWeight="SemiBold" />
              <TextBlock Text="{Binding SourceUrl}" Classes="muted" TextWrapping="Wrap" FontSize="11" />
            </StackPanel>
          </Grid>

          <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}" TextWrapping="Wrap" />

          <Grid>
            <Button HorizontalAlignment="Right"
                    Classes="primary"
                    Content="{Binding SubmitButtonText}"
                    Command="{Binding SubmitCommand}"
                    IsVisible="{Binding !ShowFeedback}"
                    MinWidth="132" />
            <Button HorizontalAlignment="Right"
                    Classes="primary"
                    Content="{Binding NextButtonText}"
                    Command="{Binding NextCommand}"
                    IsVisible="{Binding ShowFeedback}"
                    MinWidth="132" />
          </Grid>
        </StackPanel>
      </Border>
    </ScrollViewer>
  </Grid>
</UserControl>
