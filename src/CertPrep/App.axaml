<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dashboard="clr-namespace:CertPrep.Features.Dashboard"
             xmlns:dashboardViews="clr-namespace:CertPrep.Features.Dashboard.Views"
             xmlns:options="clr-namespace:CertPrep.Features.Options"
             xmlns:optionsViews="clr-namespace:CertPrep.Features.Options.Views"
             xmlns:practice="clr-namespace:CertPrep.Features.Practice"
             xmlns:practiceViews="clr-namespace:CertPrep.Features.Practice.Views"
             xmlns:progress="clr-namespace:CertPrep.Features.Progress"
             xmlns:progressViews="clr-namespace:CertPrep.Features.Progress.Views"
             xmlns:results="clr-namespace:CertPrep.Features.Results"
             xmlns:resultsViews="clr-namespace:CertPrep.Features.Results.Views"
             x:Class="CertPrep.App"
             RequestedThemeVariant="Default">

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="CanvasBrush" Color="#080808" />
          <SolidColorBrush x:Key="SidebarBrush" Color="#0B0B0B" />
          <SolidColorBrush x:Key="SurfaceBrush" Color="#111111" />
          <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="#181818" />
          <SolidColorBrush x:Key="SurfaceSoftBrush" Color="#202020" />
          <SolidColorBrush x:Key="StrokeBrush" Color="#2B2B2B" />
          <SolidColorBrush x:Key="TextBrush" Color="#F5F4F1" />
          <SolidColorBrush x:Key="TextMutedBrush" Color="#A6A4A0" />
          <SolidColorBrush x:Key="AccentBrush" Color="#77A7FF" />
          <SolidColorBrush x:Key="AccentStrongBrush" Color="#3D7FE8" />
          <SolidColorBrush x:Key="AccentSoftBrush" Color="#17191D" />
          <SolidColorBrush x:Key="ChoiceHoverBrush" Color="#222A36" />
          <SolidColorBrush x:Key="ChoiceSelectedBrush" Color="#1B2029" />
          <SolidColorBrush x:Key="SuccessBrush" Color="#62D6A7" />
          <SolidColorBrush x:Key="SuccessSoftBrush" Color="#102A21" />
          <SolidColorBrush x:Key="DangerBrush" Color="#FF8B94" />
          <SolidColorBrush x:Key="DangerSoftBrush" Color="#2F171A" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="CanvasBrush" Color="#F4F2ED" />
          <SolidColorBrush x:Key="SidebarBrush" Color="#ECE9E2" />
          <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFEFB" />
          <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="#F0EEE8" />
          <SolidColorBrush x:Key="SurfaceSoftBrush" Color="#E7E4DC" />
          <SolidColorBrush x:Key="StrokeBrush" Color="#D0CCC2" />
          <SolidColorBrush x:Key="TextBrush" Color="#171717" />
          <SolidColorBrush x:Key="TextMutedBrush" Color="#65635F" />
          <SolidColorBrush x:Key="AccentBrush" Color="#2764D8" />
          <SolidColorBrush x:Key="AccentStrongBrush" Color="#1E5ED2" />
          <SolidColorBrush x:Key="AccentSoftBrush" Color="#E6ECF8" />
          <SolidColorBrush x:Key="ChoiceHoverBrush" Color="#E2E9F4" />
          <SolidColorBrush x:Key="ChoiceSelectedBrush" Color="#E9EDF4" />
          <SolidColorBrush x:Key="SuccessBrush" Color="#147A56" />
          <SolidColorBrush x:Key="SuccessSoftBrush" Color="#DCEFE7" />
          <SolidColorBrush x:Key="DangerBrush" Color="#B33140" />
          <SolidColorBrush x:Key="DangerSoftBrush" Color="#F8E2E5" />
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>

      <StreamGeometry x:Key="Icon.Dashboard">M3 3H10V10H3Z M14 3H21V10H14Z M3 14H10V21H3Z M14 14H21V21H14Z</StreamGeometry>
      <StreamGeometry x:Key="Icon.Progress">M4 19H20V21H4Z M5 11H9V18H5Z M10 7H14V18H10Z M15 3H19V18H15Z</StreamGeometry>
      <StreamGeometry x:Key="Icon.Play">M7 4L20 12L7 20Z</StreamGeometry>
      <StreamGeometry x:Key="Icon.Mix">M16 3H21V8H19V6.41L6.41 19H10V21H3V14H5V17.59L17.59 5H16V3Z M14.5 14.5L16 13L19 16V14H21V21H14V19H17.59L14.5 15.91Z M3 3H10V5H6.41L10.5 9.09L9.09 10.5L5 6.41V8H3V3Z</StreamGeometry>
      <StreamGeometry x:Key="Icon.Options">M19.14 12.94C19.18 12.63 19.2 12.32 19.2 12S19.18 11.37 19.14 11.06L21.23 9.43L19.23 5.97L16.78 6.96C16.28 6.58 15.73 6.26 15.13 6.03L14.76 3.4H10.76L10.39 6.03C9.79 6.26 9.24 6.58 8.74 6.96L6.29 5.97L4.29 9.43L6.38 11.06C6.34 11.37 6.32 11.69 6.32 12S6.34 12.63 6.38 12.94L4.29 14.57L6.29 18.03L8.74 17.04C9.24 17.42 9.79 17.74 10.39 17.97L10.76 20.6H14.76L15.13 17.97C15.73 17.74 16.28 17.42 16.78 17.04L19.23 18.03L21.23 14.57L19.14 12.94M12.76 15.5A3.5 3.5 0 1 1 12.76 8.5A3.5 3.5 0 0 1 12.76 15.5Z</StreamGeometry>
      <StreamGeometry x:Key="Icon.Import">M11 3H13V13H17L12 18L7 13H11Z M4 19H20V21H4Z</StreamGeometry>
      <StreamGeometry x:Key="Icon.Retry">M12 5V2L7 7L12 12V9C15.31 9 18 11.69 18 15C18 18.31 15.31 21 12 21C8.69 21 6 18.31 6 15H3C3 19.97 7.03 24 12 24C16.97 24 21 19.97 21 15C21 10.03 16.97 6 12 6Z</StreamGeometry>
    </ResourceDictionary>
  </Application.Resources>

  <Application.DataTemplates>
    <DataTemplate DataType="{x:Type dashboard:DashboardViewModel}">
      <dashboardViews:DashboardView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type options:OptionsViewModel}">
      <optionsViews:OptionsView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type practice:PracticeSetupViewModel}">
      <practiceViews:PracticeSetupView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type practice:MixedPracticeSetupViewModel}">
      <practiceViews:MixedPracticeSetupView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type practice:PracticeViewModel}">
      <practiceViews:PracticeView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type progress:ProgressViewModel}">
      <progressViews:ProgressView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type results:ResultsViewModel}">
      <resultsViews:ResultsView />
    </DataTemplate>
  </Application.DataTemplates>

  <Application.Styles>
    <FluentTheme />

    <Style Selector="Window">
      <Setter Property="Background" Value="{DynamicResource CanvasBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
      <Setter Property="FontFamily" Value="Inter" />
    </Style>

    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>
    <Style Selector="TextBlock.muted">
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    </Style>
    <Style Selector="TextBlock.eyebrow">
      <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="LetterSpacing" Value="1.2" />
    </Style>
    <Style Selector="TextBlock.h1">
      <Setter Property="FontSize" Value="28" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>
    <Style Selector="TextBlock.h2">
      <Setter Property="FontSize" Value="20" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.h3">
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Border.card">
      <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource StrokeBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="18" />
    </Style>
    <Style Selector="Border.metric">
      <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource StrokeBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="3" />
      <Setter Property="Padding" Value="14" />
    </Style>
    <Style Selector="Border.pill">
      <Setter Property="Background" Value="{DynamicResource SurfaceSoftBrush}" />
      <Setter Property="CornerRadius" Value="20" />
      <Setter Property="Padding" Value="8,4" />
    </Style>

    <Style Selector="Button">
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{DynamicResource AccentStrongBrush}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Button.secondary">
      <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource StrokeBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.nav">
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="ToggleButton.choice">
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource StrokeBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="Padding" Value="12,8" />
      <Setter Property="Margin" Value="0,0,0,5" />
      <Setter Property="MinHeight" Value="44" />
    </Style>
    <Style Selector="ToggleButton.choice:pointerover">
      <Setter Property="Background" Value="{DynamicResource ChoiceHoverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="ToggleButton.choice:checked">
      <Setter Property="Background" Value="{DynamicResource ChoiceSelectedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="ToggleButton.choice:checked:pointerover">
      <Setter Property="Background" Value="{DynamicResource ChoiceSelectedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="ToggleButton.choice:disabled">
      <Setter Property="Opacity" Value="1" />
      <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource StrokeBrush}" />
    </Style>
    <Style Selector="ToggleButton.choice:checked:disabled">
      <Setter Property="Background" Value="{DynamicResource ChoiceSelectedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="ToggleButton.choice /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource StrokeBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>
    <Style Selector="ToggleButton.choice:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource ChoiceHoverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>
    <Style Selector="ToggleButton.choice:checked /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource ChoiceSelectedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>
    <Style Selector="ToggleButton.choice:checked:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource ChoiceHoverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>
    <Style Selector="ToggleButton.choice:disabled /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource StrokeBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>
    <Style Selector="ToggleButton.choice:checked:disabled /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource ChoiceSelectedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>
    <Style Selector="Border.choiceBox">
      <Setter Property="Width" Value="18" />
      <Setter Property="Height" Value="18" />
      <Setter Property="CornerRadius" Value="3" />
      <Setter Property="BorderBrush" Value="{DynamicResource TextMutedBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="ToggleButton.choice:pointerover Border.choiceBox">
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="ToggleButton.choice:checked Border.choiceBox">
      <Setter Property="Background" Value="{DynamicResource AccentStrongBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentStrongBrush}" />
    </Style>
    <Style Selector="Border.choiceRadio">
      <Setter Property="Width" Value="18" />
      <Setter Property="Height" Value="18" />
      <Setter Property="CornerRadius" Value="9" />
      <Setter Property="BorderBrush" Value="{DynamicResource TextMutedBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="ToggleButton.choice:pointerover Border.choiceRadio">
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="ToggleButton.choice:checked Border.choiceRadio">
      <Setter Property="BorderBrush" Value="{DynamicResource AccentStrongBrush}" />
    </Style>
    <Style Selector="ToggleButton.choice.correct /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SuccessSoftBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>
    <Style Selector="ToggleButton.choice.incorrect /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource DangerSoftBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>
    <Style Selector="ToggleButton.choice.correct Border.choiceBox">
      <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
    </Style>
    <Style Selector="ToggleButton.choice.correct:checked Border.choiceBox">
      <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
    </Style>
    <Style Selector="ToggleButton.choice.incorrect:checked Border.choiceBox">
      <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
    </Style>
    <Style Selector="ToggleButton.choice.correct Border.choiceRadio">
      <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
    </Style>
    <Style Selector="ToggleButton.choice.incorrect Border.choiceRadio">
      <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
    </Style>
    <Style Selector="ToggleButton.choice.correct Ellipse.choiceMark">
      <Setter Property="Fill" Value="{DynamicResource SuccessBrush}" />
    </Style>
    <Style Selector="ToggleButton.choice.incorrect Ellipse.choiceMark">
      <Setter Property="Fill" Value="{DynamicResource DangerBrush}" />
    </Style>

    <Style Selector="ProgressBar">
      <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
      <Setter Property="Background" Value="{DynamicResource SurfaceSoftBrush}" />
      <Setter Property="Height" Value="6" />
    </Style>

    <Style Selector="ComboBox">
      <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource StrokeBrush}" />
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>
  </Application.Styles>
</Application>
