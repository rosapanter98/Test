<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AvaloniaApplication3.ViewModels.Quizzes"
             xmlns:views="clr-namespace:AvaloniaApplication3.Views.Quizzes"
             x:Class="AvaloniaApplication3.Views.Quizzes.QuizSessionView"
             x:DataType="vm:QuizSessionViewModel">

	<Grid ColumnDefinitions="380,16,*" RowDefinitions="Auto,*" Margin="16">
		<!-- Left: selection -->
		<TextBlock Grid.Column="0" Text="Quizzes" FontWeight="Bold"/>
		<views:QuizSelectionView Grid.Row="1" Grid.Column="0" DataContext="{Binding Selection}"/>

		<!-- Right: attempts -->
		<TextBlock Grid.Column="2" Text="Attempts" FontWeight="Bold"/>
		<views:AttemptsHistoryView Grid.Row="1" Grid.Column="2" DataContext="{Binding History}"/>
	</Grid>
</UserControl>
