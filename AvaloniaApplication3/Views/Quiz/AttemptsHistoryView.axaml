<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AvaloniaApplication3.ViewModels.Quizzes"
             xmlns:m="clr-namespace:AvaloniaApplication3.Models"
             x:Class="AvaloniaApplication3.Views.Quizzes.AttemptsHistoryView"
             x:DataType="vm:AttemptsHistoryViewModel"
			 x:Name="Root">

	<Grid RowDefinitions="Auto,8,*">
		<!-- toolbar omitted -->

		<ItemsControl Grid.Row="2" ItemsSource="{Binding VisibleItems}">
			<ItemsControl.ItemTemplate>
				<!-- Attempt row -->
				<DataTemplate x:DataType="vm:AttemptRowViewModel">
					<Expander Margin="0,4,0,0" Expanded="OnExpanded">
						<Expander.Header>
							<Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
								<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
									<TextBlock Text="{Binding QuizTitle}" FontWeight="Bold"/>
									<TextBlock Text="{Binding StartedAt, StringFormat={}{0:dd/MM/yy HH:mm}}"/>
									<TextBlock>
										<TextBlock.Text>
											<MultiBinding StringFormat="Score: {0}/{1}">
												<Binding Path="CorrectAnswers"/>
												<Binding Path="TotalQuestions"/>
											</MultiBinding>
										</TextBlock.Text>
									</TextBlock>
								</StackPanel>

								<Button Grid.Column="1"
										Content="Delete"
										HorizontalAlignment="Right"
										Command="{Binding DataContext.DeleteAttemptCommand, ElementName=Root}"
										CommandParameter="{Binding}" />
							</Grid>
						</Expander.Header>


						<!-- Per-question list -->
						<ItemsControl ItemsSource="{Binding Items}">
							<ItemsControl.ItemTemplate>
								<!-- Question -->
								<DataTemplate x:DataType="vm:AttemptItemRowViewModel">
									<StackPanel Margin="0,8,0,0">
										<TextBlock Text="{Binding QuestionText}" FontWeight="Bold" Margin="0,0,0,4"/>
										<TextBlock Text="{Binding IsCorrect, Converter={StaticResource BoolToResultTextConverter}}"
												   FontWeight="Bold" Margin="0,0,0,6"/>

										<!-- Answers (bind to model answers) -->
										<ItemsControl ItemsSource="{Binding Answers}">
											<ItemsControl.ItemTemplate>
												<DataTemplate x:DataType="m:QuizAttemptItemAnswer">
													<Border Padding="6" Margin="0,2,0,0" CornerRadius="4" BorderThickness="2"
															BorderBrush="{Binding IsCorrect, Converter={StaticResource AnswerCorrectBrushConverter}}">
														<Grid ColumnDefinitions="*,Auto">
															<!-- Color the text too (optional, remove Foreground if you only want outline) -->
															<TextBlock Grid.Column="0" Text="{Binding Text}"
																	   Foreground="{Binding IsCorrect, Converter={StaticResource AnswerCorrectBrushConverter}}"/>

															<!-- Right-side 'X' only where user answered -->
															<TextBlock Grid.Column="1" Margin="8,0,0,0"
																	   Text="{Binding IsSelected, Converter={StaticResource SelectedMarkConverter}}"/>
														</Grid>
													</Border>
												</DataTemplate>

											</ItemsControl.ItemTemplate>
										</ItemsControl>
									</StackPanel>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</Expander>
				</DataTemplate>
			</ItemsControl.ItemTemplate>
		</ItemsControl>
	</Grid>
</UserControl>
