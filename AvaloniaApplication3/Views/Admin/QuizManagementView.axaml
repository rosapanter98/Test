<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AvaloniaApplication3.ViewModels.Admin"
             xmlns:views="clr-namespace:AvaloniaApplication3.Views.Admin"
             x:Class="AvaloniaApplication3.Views.Admin.QuizManagementView"
             x:DataType="vm:QuizManagementViewModel"
             x:Name="Root">

	<Grid Margin="20" ColumnDefinitions="2*,3*" ColumnSpacing="24">
		<!-- Left Column -->
		<StackPanel Grid.Column="0" Spacing="14">
			<TextBlock Text="Quiz Management" FontSize="20" FontWeight="Bold" />

			<TextBlock Text="{Binding Quizzes.Count, StringFormat='Total Quizzes: {0}'}" FontStyle="Italic" FontSize="12" Foreground="Gray"/>

			<StackPanel Orientation="Horizontal" Spacing="8">
				<Button Content="New Quiz" Command="{Binding ToggleCreateFormCommand}" Padding="10,4"/>
				<Button Content="Import Quiz JSON…" Command="{Binding ImportQuizCommand}" Padding="10,4"/>
			</StackPanel>

			<TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="Gray" />

			<!-- Create Quiz Form -->
			<StackPanel Spacing="6" IsVisible="{Binding ShowCreateForm}" Margin="0,6,0,6">
				<TextBlock Text="Create New Quiz" FontWeight="Bold" />
				<TextBox Watermark="Quiz title" Text="{Binding NewQuizTitle, Mode=TwoWay}" />
				<TextBox Watermark="Description (optional)" Text="{Binding NewQuizDescription, Mode=TwoWay}" AcceptsReturn="True" Height="60"/>
				<Button Content="Create Quiz" Command="{Binding CreateQuizCommand}" Padding="8,4"/>
			</StackPanel>

			<!-- Quiz List -->
			<ItemsControl ItemsSource="{Binding Quizzes}">
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border BorderBrush="#CCC" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,6,0,0">
							<DockPanel>
								<StackPanel DockPanel.Dock="Left" Spacing="2">
									<TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
									<TextBlock Text="{Binding Questions.Count, StringFormat='Questions: {0}'}" FontSize="12" Foreground="Gray"/>
								</StackPanel>
								<StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
									<Button Content="Edit"
                                            Command="{Binding DataContext.EditQuizCommand, ElementName=Root}"
                                            CommandParameter="{Binding}" Padding="8,2"/>
									<Button Content="Delete"
                                            Command="{Binding DataContext.DeleteQuizCommand, ElementName=Root}"
                                            CommandParameter="{Binding}" Padding="8,2"/>
								</StackPanel>
							</DockPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</StackPanel>

		<!-- Right Column (Editor) -->
		<Border Grid.Column="1" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="16">
			<ContentControl Content="{Binding CurrentQuizEditor}" />
		</Border>
	</Grid>
</UserControl>
