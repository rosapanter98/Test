<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AvaloniaApplication3.ViewModels.Admin"
             xmlns:views="clr-namespace:AvaloniaApplication3.Views.Admin"
             x:Class="AvaloniaApplication3.Views.Admin.QuizEditorView"
             x:DataType="vm:QuizEditorViewModel"
             x:Name="Root">

	<ScrollViewer>
		<StackPanel Margin="20" Spacing="12">

			<TextBlock Text="{Binding Quiz.Title}" FontSize="18" FontWeight="Bold" />
			<TextBlock Text="{Binding Quiz.Description}" FontStyle="Italic" />

			<Button Content="Add Question"
                    Command="{Binding AddQuestionCommand}"
                    HorizontalAlignment="Left" />

			<ItemsControl ItemsSource="{Binding Questions}">
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Grid ColumnDefinitions="Auto,Auto" Margin="0,4,0,0">
							<!-- Expander (left side) -->
							<Expander IsExpanded="False"
                                      Grid.Column="0"
                                      Width="400"
                                      MinHeight="40"
                                      Padding="6"
                                      BorderBrush="Gray"
                                      BorderThickness="1">
								<Expander.Header>
									<TextBlock Text="{Binding Question.Text}"
                                               TextTrimming="CharacterEllipsis"
											   TextAlignment="Left"
                                               MaxWidth="350"
                                               VerticalAlignment="Center" />
								</Expander.Header>

								<views:QuestionEditorView DataContext="{Binding}" />
							</Expander>

							<!-- Delete Button (right side) -->
							<Button Content="X"
                                    Grid.Column="1"
                                    Command="{Binding DataContext.RemoveQuestionCommand, ElementName=Root}"
                                    CommandParameter="{Binding}"
                                    Background="Red"
                                    Foreground="White"
                                    Width="28"
                                    Height="28"
                                    Margin="8,6,0,0"
                                    VerticalAlignment="Top" />
						</Grid>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

		</StackPanel>
	</ScrollViewer>
</UserControl>
