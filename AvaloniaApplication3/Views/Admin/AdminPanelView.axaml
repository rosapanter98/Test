<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AvaloniaApplication3.ViewModels.Admin"
             x:Class="AvaloniaApplication3.Views.Admin.AdminPanelView"
             x:DataType="vm:AdminPanelViewModel"
             x:Name="Root">

	<ScrollViewer>
		<StackPanel Margin="20" Spacing="12">
			<!-- Navigation Buttons -->
			<ItemsControl ItemsSource="{Binding SectionNames}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<UniformGrid Columns="2" HorizontalAlignment="Left" />
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Button Content="{Binding}"
								Command="{Binding DataContext.ToggleSectionCommand, ElementName=Root}"
								CommandParameter="{Binding}"
								Margin="0,0,10,0"
								Padding="8,4"/>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>


			<!-- Save Button and Status -->
			<!-- <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
				<Button Content="Save"
                        Command="{Binding SaveCommand}"
                        Padding="10,4" />
				<TextBlock Text="{Binding SaveStatus}"
                           FontSize="12"
                           VerticalAlignment="Center"/>
			</StackPanel>-->

			<!-- Section Content -->
			<ContentControl Content="{Binding CurrentSection}" Margin="0,20,0,0" />
		</StackPanel>
	</ScrollViewer>
</UserControl>
