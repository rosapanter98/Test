<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AvaloniaApplication3.ViewModels"
             x:Class="AvaloniaApplication3.Views.AttemptsHistoryView"
             x:DataType="vm:AttemptsHistoryViewModel">
	<Grid RowDefinitions="Auto,8,*">
		<StackPanel Orientation="Horizontal" Spacing="8">
			<Button Content="Refresh" Command="{Binding RefreshCommand}"/>
			<TextBlock Text="{Binding Items.Count, StringFormat='Total: {0}'}"/>
			<TextBlock Text="Loading..." IsVisible="{Binding IsLoading}"/>
		</StackPanel>

		<ItemsControl Grid.Row="2" ItemsSource="{Binding Items}">
			<ItemsControl.ItemTemplate>
				<DataTemplate>
					<Border Margin="0,4,0,0" Padding="6" BorderBrush="Gray" BorderThickness="1">
						<StackPanel>
							<TextBlock Text="{Binding Quiz.Title}" FontWeight="Bold"/>
							<!-- changed -->
							<TextBlock Text="{Binding StartedAt, StringFormat='Started: {0:u}'}"/>
							<TextBlock Text="{Binding CompletedAt, StringFormat='Completed: {0:u}'}"/>
							<TextBlock>
								<TextBlock.Text>
									<MultiBinding StringFormat="Score: {0}/{1}">
										<Binding Path="CorrectAnswers"/>
										<Binding Path="TotalQuestions"/>
									</MultiBinding>
								</TextBlock.Text>
							</TextBlock>
						</StackPanel>
					</Border>
				</DataTemplate>
			</ItemsControl.ItemTemplate>
		</ItemsControl>
	</Grid>
</UserControl>
